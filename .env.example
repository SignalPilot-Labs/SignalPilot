# =============================================================================
# SignalPilot — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Required: GitHub ---

# GitHub PAT with repo scope (used by agent for push/PR, never exposed to LLM)
GIT_TOKEN=ghp_...

# Fine-grained PAT for Firecracker sandbox (repo contents read)
FGAT_GIT_TOKEN=github_pat_...

# GitHub repo slug — agent is gated to only operate on this repo
GITHUB_REPO=YourOrg/SignalPilot

# --- Required: Claude / Anthropic ---

# Claude Code OAuth token (authenticates CLI + SDK inside the agent container)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# --- Optional ---

# Max budget per agent run in USD. 0 = unlimited (default: 0)
# MAX_BUDGET_USD=0

# Benchmark data directory on the host. Mounted into agent container at /bench.
# Point this at a drive with space — Spider2 repo clone is ~2-3 GB.
SP_BENCHMARK_DIR=D:\signalpilot-bench

# --- Benchmark paths (optional — defaults to relative paths if unset) ---

# Path to the Spider2-DBT dataset directory (contains examples/, evaluation_suite/)
# SPIDER2_DBT_DIR=/path/to/spider2-repo/spider2-dbt

# Path to the root Spider2 repo clone (used by setup_dbt.py)
# SPIDER2_REPO_DIR=/path/to/spider2-repo

# SignalPilot gateway URL (used by benchmark runners and MCP server)
# SP_GATEWAY_URL=http://localhost:3300

# --- Internal (set by docker-compose, do not override) ---
# AUDIT_DB_URL=postgresql://improve_admin:Impr0ve!Aud1t@postgres:5432/improve_audit
# SP_SANDBOX_MANAGER_URL=http://host.docker.internal:8180
# AGENT_API_URL=http://agent:8500
