FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/sp-notebook

# Clone the signalpilot-notebook fork at build time
ARG NOTEBOOK_REPO=https://github.com/SignalPilot-Labs/signalpilot-notebook.git
ARG NOTEBOOK_BRANCH=feature/cloud-filesystem
ARG GIT_TOKEN=""
RUN if [ -n "$GIT_TOKEN" ]; then \
      git clone --depth 1 --branch ${NOTEBOOK_BRANCH} https://${GIT_TOKEN}@github.com/SignalPilot-Labs/signalpilot-notebook.git . ; \
    else \
      git clone --depth 1 --branch ${NOTEBOOK_BRANCH} ${NOTEBOOK_REPO} . ; \
    fi

# Install marimo (pin starlette/uvicorn to known-working versions)
RUN pip install --no-cache-dir -e . && \
    pip install --no-cache-dir "starlette==0.47.2" "uvicorn==0.35.0"

# dbt + adapters
RUN pip install --no-cache-dir \
    "dbt-core>=1.9,<2" \
    "dbt-duckdb>=1.9" \
    "dbt-postgres>=1.9" \
    "dbt-snowflake>=1.9"

# Common data packages + notebook deps
RUN pip install --no-cache-dir \
    httpx \
    requests \
    duckdb \
    polars \
    pandas \
    pyarrow \
    sqlglot \
    altair \
    anthropic \
    claude-agent-sdk \
    mcp \
    pydantic-ai-slim \
    scikit-learn \
    scipy \
    seaborn \
    plotly \
    pyyaml \
    jinja2 \
    python-dotenv

# Non-root user
RUN groupadd -g 10001 notebook && \
    useradd -r -u 10001 -g notebook notebook && \
    mkdir -p /workspace /home/notebook/.sp && \
    chown -R notebook:notebook /workspace /home/notebook /opt/sp-notebook

USER notebook
WORKDIR /workspace

EXPOSE 2718

HEALTHCHECK --interval=10s --timeout=5s --start-period=30s \
    CMD curl -sf http://localhost:2718/api/health || curl -sf http://localhost:2718/ -o /dev/null || exit 1

ENV SP_GATEWAY_URL=""
ENV SP_API_KEY=""

CMD ["sp", "edit", "--host", "0.0.0.0", "--port", "2718", "--headless", "/workspace"]
