FROM node:22-alpine AS builder
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10 --activate

ARG NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_DEPLOYMENT_MODE=local
ARG NEXT_PUBLIC_GATEWAY_URL=http://localhost:3300

ENV NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=$NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_DEPLOYMENT_MODE=$NEXT_PUBLIC_DEPLOYMENT_MODE
ENV NEXT_PUBLIC_GATEWAY_URL=$NEXT_PUBLIC_GATEWAY_URL

# Copy workspace config + packages
COPY pnpm-workspace.yaml ./
COPY sp-dev-work/signalpilot/web/package.json signalpilot/web/
COPY sp-notebook/packages/ sp-notebook/packages/

# Adjust workspace paths for the flat Docker layout
RUN sed -i 's|sp-dev-work/signalpilot/web|signalpilot/web|' pnpm-workspace.yaml

# Install deps
RUN cd signalpilot/web && pnpm install --no-frozen-lockfile

# Copy web app source
COPY sp-dev-work/signalpilot/web/ signalpilot/web/

# Build (standalone output bundles everything needed to run)
RUN cd signalpilot/web && pnpm run build

# ── Production runner ─────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

# Copy standalone server (includes node_modules + server.js)
COPY --from=builder /app/signalpilot/web/.next/standalone/ ./
# Copy static assets into the path the standalone server expects
COPY --from=builder /app/signalpilot/web/.next/static ./signalpilot/web/.next/static
COPY --from=builder /app/signalpilot/web/public ./signalpilot/web/public

# Entrypoint: wait for local API key, then start standalone server
RUN printf '#!/bin/sh\ni=0\nwhile [ ! -f /shared/local_api_key ] && [ "$i" -lt 30 ]; do\n  sleep 1\n  i=$((i+1))\ndone\nif [ -f /shared/local_api_key ]; then\n  export SP_LOCAL_API_KEY="$(cat /shared/local_api_key)"\nfi\nexec node signalpilot/web/server.js\n' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

ENV PORT=3200
ENV HOSTNAME=0.0.0.0
EXPOSE 3200
CMD ["/app/entrypoint.sh"]
