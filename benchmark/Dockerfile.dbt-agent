FROM python:3.12-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential libpq-dev libssl-dev libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# Node.js (required for Claude Code CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Python: dbt-duckdb + data tools + Claude Agent SDK + MCP + gateway deps
RUN pip install --no-cache-dir \
    dbt-duckdb \
    duckdb \
    pandas \
    pyarrow \
    claude-agent-sdk \
    httpx \
    "mcp[cli]" \
    aiofiles \
    pydantic \
    sqlglot

# Non-root user (Claude CLI requires this)
RUN useradd -m agentuser \
    && mkdir -p /home/agentuser/.claude /workspace \
    && echo '{}' > /home/agentuser/.claude.json \
    && chown -R agentuser:agentuser /home/agentuser /workspace

USER agentuser

RUN git config --global user.name "Benchmark Agent" \
    && git config --global user.email "benchmark@noreply.com" \
    && git config --global --add safe.directory '*'

WORKDIR /workspace

COPY --chown=agentuser:agentuser dbt_agent_entrypoint.sh /usr/local/bin/entrypoint.sh
COPY --chown=agentuser:agentuser dbt_agent_runner.py /app/dbt_agent_runner.py

USER root
RUN chmod +x /usr/local/bin/entrypoint.sh && \
    apt-get update && apt-get install -y --no-install-recommends gosu libfaketime && rm -rf /var/lib/apt/lists/*

# libfaketime installed but NOT globally enabled (breaks TLS certificate validation).
# Wrap the dbt binary so ALL dbt commands see 2024-09-08 as current_date.
# This is non-discriminate: every task gets the same date for date_spine/current_timestamp.
ENV FAKETIME="2024-09-08 12:00:00"
# Wrap dbt: faketime for correct current_date, DO_NOT_TRACK to disable telemetry.
# Without DO_NOT_TRACK, dbt makes HTTPS calls on exit that hang forever under
# faketime (TLS certificates appear "not yet valid" with a 2024-09-08 clock).
RUN DBT_REAL=$(which dbt) && \
    mv "$DBT_REAL" "${DBT_REAL}.real" && \
    printf '#!/bin/bash\n# Only apply faketime to commands that execute SQL (run/compile/build).\n# deps/parse/version need real network + real clock for SSL.\ncase "$1" in\n  run|compile|build|run-operation|seed|snapshot|test)\n    exec env LD_PRELOAD=/usr/lib/x86_64-linux-gnu/faketime/libfaketime.so.1 FAKETIME="${FAKETIME:-2024-09-08 12:00:00}" FAKETIME_DONT_FAKE_MONOTONIC=1 FAKETIME_NO_CACHE=1 DO_NOT_TRACK=1 DBT_NO_VERSION_CHECK=1 "${0}.real" "$@"\n    ;;\n  *)\n    exec env DO_NOT_TRACK=1 DBT_NO_VERSION_CHECK=1 "${0}.real" "$@"\n    ;;\nesac\n' > "$DBT_REAL" && \
    chmod +x "$DBT_REAL"

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
