# Reproducible build environment for Spider2-DBT evaluation.
#
# Pinned to the versions that were latest on 2025-06-26, the day the Spider2
# gold DBs were last updated. That's our best guess at what Spider2 used, since
# their published Dockerfile intentionally uses unpinned versions.
#
# Runtime: threads=1 both in dbt and DuckDB so the non-deterministic UNION ALL
# arm ordering in pre-shipped files like int__all_visits.sql stops depending
# on parallel execution.

FROM python:3.11-slim

WORKDIR /work

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip==24.1.2

# Pinned stack matching the Spider2 gold's 2025-06-26 update date.
RUN pip install --no-cache-dir \
    "duckdb==1.3.1" \
    "dbt-core==1.9.8" \
    "dbt-duckdb==1.9.4"

# Keep the container alive so we can `docker exec` into it iteratively
# without rebuilding. Task data is mounted at /work/task by the host.
CMD ["sleep", "infinity"]
