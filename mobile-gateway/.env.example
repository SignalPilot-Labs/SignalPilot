# SignalPilot Mobile Gateway — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env

# Gateway port (default: 8080)
GATEWAY_PORT=8080

# JWT secret for session tokens — IMPORTANT: set this for production!
# Generate with: openssl rand -hex 64
JWT_SECRET=

# Session duration in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# Backend service URLs (defaults work for Docker with host.docker.internal)
WEB_UI_URL=http://host.docker.internal:3200
MONITOR_UI_URL=http://host.docker.internal:3400
GATEWAY_API_URL=http://host.docker.internal:3300
MONITOR_API_URL=http://host.docker.internal:3401

# Cloudflare Tunnel (for remote access)
# Set your domain here when using Cloudflare Tunnel
TUNNEL_DOMAIN=
# Tunnel token from Cloudflare Zero Trust dashboard
TUNNEL_TOKEN=
