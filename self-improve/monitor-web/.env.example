# SignalPilot Monitor Web — Environment Variables
#
# Copy to .env.local and customize for your deployment.

# Monitor API URL (used for API calls, SSE streams, and CSP header)
# Local: http://localhost:3401
# Cloudflare: https://monitor-api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3401

# Server-side API URL (used in next.config.ts rewrites)
# Same as NEXT_PUBLIC_API_URL unless you need a different internal route
API_URL=http://localhost:3401
