# SignalPilot Gateway — Environment Variables
#
# Copy to .env and customize for your deployment.

# Data directory for settings, connections, and audit log (default: ~/.signalpilot)
SP_DATA_DIR=/data

# Sandbox manager URL
# Local docker-compose: http://sandbox:8080
# External/BYOF: http://your-sandbox-host:8180
SP_SANDBOX_MANAGER_URL=http://sandbox:8080

# Sandbox API key — must match SP_SANDBOX_API_KEY on the sandbox manager
# Generate with: openssl rand -hex 32
SP_SANDBOX_API_KEY=

# Gateway URL (used by sandbox for callbacks)
SP_GATEWAY_URL=http://gateway:3300

# CORS allowed origins (comma-separated)
# For Cloudflare: https://web.yourdomain.com,https://monitor.yourdomain.com
SP_ALLOWED_ORIGINS=http://localhost:3200,http://localhost:3400

# Audit log max file size in bytes before rotation (default: 10MB)
SP_AUDIT_MAX_BYTES=10485760

# Max audit entries to scan per query (default: 50000)
SP_AUDIT_MAX_SCAN=50000
