# Deployment mode: "cloud" (auth required) or "local" (auth optional, default)
NEXT_PUBLIC_DEPLOYMENT_MODE=local

# Clerk authentication (required for cloud mode, optional for local)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Gateway URL
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3300

# Backend API URL (future use)
NEXT_PUBLIC_BACKEND_URL=
